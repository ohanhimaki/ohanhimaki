@code {
    [Parameter] public string Art { get; set; } = "";
    private bool smallFont = true;

    
}

<div class="ascii-container @(smallFont ? "small-font" : "")">
    <pre>@Art</pre>
</div>

<style>
    .ascii-container {
        text-align: center;
        margin: 20px auto;
    }
    pre {
        font-family: monospace;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
    .small-font pre {
        font-size: 4px; /* Adjust as needed */
        line-height: 4px;
    }
</style>
